# このファイルをコピーして .env を作成し、実際の値を設定してください
# cp .env.example .env
# .env は .gitignore に追加し、リポジトリにコミットしないこと

# ---- Google OAuth ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- JWT ----
JWT_SECRET=                        # 256bit 以上のランダム文字列
JWT_ISSUER=https://your-domain.com
JWT_AUDIENCE=fridge-app

# ---- データベース ----
DB_URL=jdbc:postgresql://localhost:5432/fridgeapp

# Docker postgres 管理ユーザー（コンテナ初回起動時のみ使用）
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=           # 英数字のみ推奨（特殊文字はロール作成スクリプトで問題になる場合あり）

# Flyway マイグレーション用（DDL + DML 権限）
DB_MIGRATOR_USER=fridgeapp_migrator
DB_MIGRATOR_PASSWORD=        # 英数字のみ推奨

# Spring Boot アプリ実行用（DML のみ）
DB_APP_USER=fridgeapp_app
DB_APP_PASSWORD=             # 英数字のみ推奨

# ---- CORS ----
# 本番環境では実際のフロントエンド URL を指定する
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- ストレージ ----
STORAGE_TYPE=local                 # local | s3 | supabase
STORAGE_LOCAL_PATH=./storage

# S3 使用時のみ設定
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=

# Supabase 使用時のみ設定
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
