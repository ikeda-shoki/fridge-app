# このファイルをコピーして .env を作成し、実際の値を設定してください
# cp .env.example .env
# .env は .gitignore に追加し、リポジトリにコミットしないこと
#
# この .env は Spring Boot が設定ソースとして読み込む（application.yml の spring.config.import）。
# .properties 形式として解釈されるため、以下に注意すること:
#   - 行末のインラインコメント（KEY=value  # メモ）は書かない。「# メモ」まで値に含まれてしまう
#   - コメントは値の「上の行」に書く
#   - 値をクォートで囲まない（引用符も値の一部になる）

# ---- Google OAuth ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- JWT ----
# HMAC-SHA の署名鍵。32 文字（=256bit）以上必須。不足すると起動時にエラーになる
# 生成例: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=
JWT_ISSUER=https://your-domain.com
JWT_AUDIENCE=fridge-app

# ---- データベース ----
DB_URL=jdbc:postgresql://localhost:5432/fridgeapp

# Docker postgres 管理ユーザー（コンテナ初回起動時のみ使用）
# 英数字のみ推奨（特殊文字はロール作成スクリプトで問題になる場合あり）
DB_ADMIN_USER=postgres
DB_ADMIN_PASSWORD=

# Flyway マイグレーション用（DDL + DML 権限）。英数字のみ推奨
DB_MIGRATOR_USER=fridgeapp_migrator
DB_MIGRATOR_PASSWORD=

# Spring Boot アプリ実行用（DML のみ）。英数字のみ推奨
DB_APP_USER=fridgeapp_app
DB_APP_PASSWORD=

# ---- CORS ----
# 本番環境では実際のフロントエンド URL を指定する
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- ストレージ ----
# local | s3 | supabase
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./storage

# S3 使用時のみ設定
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=

# Supabase 使用時のみ設定
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_STORAGE_BUCKET=
